<!DOCTYPE html>
<html lang="zh-CN">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %></title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css" rel="stylesheet">
    <style>
        :root {
            --primary: #1a3a6c;
            --primary-light: #2a4a7c;
            --gold: #c8a45c;
            --gold-light: #d4b46a;
            --success: #28a745;
            --warning: #ffc107;
            --danger: #dc3545;
            --info: #17a2b8;
            --bg-light: #f8f9fc;
            --border: #e0e4ea;
        }
        body { background: var(--bg-light); color: #333; font-family: 'Noto Sans SC', -apple-system, 'PingFang SC', 'Microsoft YaHei', sans-serif; }
        .admin-sidebar { position: fixed; left: 0; top: 0; bottom: 0; width: 260px; background: linear-gradient(180deg, #0d2240 0%, #1a3a6c 100%); border-right: 3px solid var(--gold); padding: 0; z-index: 100; }
        .sidebar-brand { padding: 24px 20px; border-bottom: 1px solid rgba(255,255,255,0.1); margin-bottom: 16px; background: rgba(0,0,0,0.2); }
        .sidebar-brand h4 { color: var(--gold); margin: 0; font-weight: 700; display: flex; align-items: center; gap: 10px; }
        .sidebar-nav { padding: 0 12px; }
        .sidebar-nav .nav-link { color: rgba(255,255,255,0.7); padding: 14px 16px; border-radius: 8px; margin: 4px 0; display: flex; align-items: center; gap: 12px; transition: all 0.3s; font-size: 15px; }
        .sidebar-nav .nav-link:hover { color: #fff; background: rgba(200,164,92,0.2); }
        .sidebar-nav .nav-link.active { color: #fff; background: linear-gradient(90deg, rgba(200,164,92,0.3) 0%, transparent 100%); border-left: 4px solid var(--gold); font-weight: 600; }
        .sidebar-nav .nav-link i { font-size: 20px; width: 24px; }
        .admin-main { margin-left: 260px; padding: 32px; min-height: 100vh; }
        .admin-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 24px; }
        .admin-header h2 { margin: 0; color: var(--primary); font-weight: 700; font-size: 28px; }
        .admin-header .subtitle { color: #888; font-size: 14px; margin-top: 4px; }
        .welcome-card { background: linear-gradient(135deg, var(--primary) 0%, var(--primary-light) 100%); border-radius: 16px; padding: 32px; color: #fff; margin-bottom: 32px; position: relative; overflow: hidden; }
        .welcome-card::before { content: ''; position: absolute; right: -50px; top: -50px; width: 200px; height: 200px; background: rgba(255,255,255,0.05); border-radius: 50%; }
        .welcome-card::after { content: ''; position: absolute; right: 50px; bottom: -80px; width: 160px; height: 160px; background: rgba(200,164,92,0.15); border-radius: 50%; }
        .welcome-card h3 { margin: 0 0 8px; font-weight: 700; font-size: 24px; }
        .welcome-card p { margin: 0; opacity: 0.9; font-size: 15px; }
        .welcome-card .date { margin-top: 16px; font-size: 14px; opacity: 0.8; }
        .stat-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 20px; margin-bottom: 32px; }
        .stat-card { background: #fff; border-radius: 12px; padding: 24px; text-decoration: none; display: block; color: inherit; box-shadow: 0 2px 12px rgba(0,0,0,0.06); transition: all 0.3s; border: 1px solid var(--border); position: relative; overflow: hidden; }
        .stat-card::before { content: ''; position: absolute; top: 0; left: 0; right: 0; height: 4px; }
        .stat-card:hover { transform: translateY(-4px); box-shadow: 0 8px 24px rgba(0,0,0,0.12); }
        .stat-card.users::before { background: var(--primary); }
        .stat-card.regs::before { background: var(--success); }
        .stat-card.works::before { background: var(--gold); }
        .stat-card.anns::before { background: var(--info); }
        .stat-card .icon-wrap { width: 56px; height: 56px; border-radius: 12px; display: flex; align-items: center; justify-content: center; margin-bottom: 16px; }
        .stat-card.users .icon-wrap { background: rgba(26,58,108,0.1); color: var(--primary); }
        .stat-card.regs .icon-wrap { background: rgba(40,167,69,0.1); color: var(--success); }
        .stat-card.works .icon-wrap { background: rgba(200,164,92,0.15); color: var(--gold); }
        .stat-card.anns .icon-wrap { background: rgba(23,162,184,0.1); color: var(--info); }
        .stat-card .icon-wrap i { font-size: 28px; }
        .stat-card .stat-value { font-size: 36px; font-weight: 800; color: #1a1a1a; margin-bottom: 4px; }
        .stat-card .stat-label { color: #666; font-size: 14px; font-weight: 500; }
        .section-card { background: #fff; border-radius: 12px; border: 1px solid var(--border); margin-bottom: 24px; overflow: hidden; }
        .section-header { padding: 20px 24px; border-bottom: 1px solid var(--border); display: flex; justify-content: space-between; align-items: center; background: #fafafa; }
        .section-header h4 { margin: 0; color: var(--primary); font-weight: 700; font-size: 18px; display: flex; align-items: center; gap: 10px; }
        .section-header h4 i { color: var(--gold); }
        .work-stat-row { display: flex; gap: 16px; padding: 20px 24px; background: #f8f9fc; }
        .work-stat-chip { flex: 1; background: #fff; border-radius: 10px; padding: 16px; text-align: center; text-decoration: none; color: inherit; border: 2px solid var(--border); transition: all 0.3s; }
        .work-stat-chip:hover { border-color: var(--primary); transform: scale(1.02); }
        .work-stat-chip.total { border-color: var(--primary); }
        .work-stat-chip.total .ws-value { color: var(--primary); }
        .work-stat-chip.pending .ws-value { color: var(--warning); }
        .work-stat-chip.approved .ws-value { color: var(--success); }
        .work-stat-chip.rejected .ws-value { color: var(--danger); }
        .ws-value { font-size: 28px; font-weight: 800; margin-bottom: 4px; }
        .ws-label { font-size: 13px; color: #666; font-weight: 500; }
        .admin-table { margin: 0; }
        .admin-table thead { background: var(--primary); }
        .admin-table th { color: #fff; font-weight: 600; border: none; padding: 14px 20px; font-size: 14px; }
        .admin-table td { border-color: var(--border); padding: 14px 20px; vertical-align: middle; font-size: 14px; }
        .admin-table tbody tr:hover { background: rgba(26,58,108,0.04); }
        .badge-status { padding: 5px 14px; border-radius: 20px; font-size: 12px; font-weight: 600; }
        .badge-pending, .badge-submitted { background: rgba(255,193,7,0.15); color: #b8860b; }
        .badge-approved { background: rgba(40,167,69,0.15); color: #28a745; }
        .badge-rejected { background: rgba(220,53,69,0.15); color: #dc3545; }
        .btn-admin { background: var(--primary); color: #fff; border: none; border-radius: 8px; padding: 8px 20px; font-weight: 600; transition: all 0.3s; }
        .btn-admin:hover { background: var(--primary-light); color: #fff; }
        .btn-outline-admin { background: transparent; color: var(--primary); border: 2px solid var(--primary); border-radius: 8px; padding: 6px 18px; font-weight: 600; transition: all 0.3s; }
        .btn-outline-admin:hover { background: var(--primary); color: #fff; }
        .empty-state { padding: 48px; text-align: center; color: #999; }
        .empty-state i { font-size: 48px; margin-bottom: 16px; opacity: 0.5; }
        .quick-actions { display: flex; gap: 12px; margin-top: 16px; }
        .quick-actions a { background: rgba(255,255,255,0.2); color: #fff; border: 1px solid rgba(255,255,255,0.3); padding: 10px 20px; border-radius: 8px; text-decoration: none; color: #fff; font-weight: 600; transition: all 0.3s; }
        .quick-actions a:hover { background: rgba(255,255,255,0.3); color: #fff; }
    </style>
</head>
<body>
    <div class="admin-sidebar">
        <div class="sidebar-brand">
            <h4><i class="bi bi-trophy-fill"></i> 凯文杯管理</h4>
        </div>
        <nav class="sidebar-nav">
            <a class="nav-link active" href="/admin/dashboard"><i class="bi bi-speedometer2"></i> 仪表盘</a>
            <a class="nav-link" href="/admin/users"><i class="bi bi-person-gear"></i> 注册用户</a>
            <a class="nav-link" href="/admin/registrations"><i class="bi bi-people-fill"></i> 报名管理</a>
            <a class="nav-link" href="/admin/works"><i class="bi bi-folder2-open"></i> 作品管理</a>
            <a class="nav-link" href="/admin/announcements"><i class="bi bi-megaphone-fill"></i> 公告管理</a>
            <a class="nav-link" href="/admin/site-config"><i class="bi bi-gear-fill"></i> 首页设置</a>
            <a class="nav-link" href="/admin/logout"><i class="bi bi-box-arrow-left"></i> 退出登录</a>
        </nav>
    </div>

    <div class="admin-main">
        <div class="welcome-card">
            <h3>欢迎回来，<%= admin.real_name || admin.username %></h3>
            <p>今天是凯文杯大赛管理系统的主控制台，您可以在这里监控赛事进展和管理各项内容。</p>
            <div class="date"><i class="bi bi-calendar3"></i> <%= new Date().toLocaleDateString('zh-CN', { weekday: 'long', year: 'numeric', month: 'long', day: 'numeric' }) %></div>
            <div class="quick-actions">
                <a href="/admin/registrations"><i class="bi bi-person-plus"></i> 审核报名</a>
                <a href="/admin/works"><i class="bi bi-folder-check"></i> 评审作品</a>
                <a href="/admin/announcements"><i class="bi bi-plus-circle"></i> 发布公告</a>
            </div>
        </div>

        <div class="stat-grid">
            <a class="stat-card regs" href="/admin/registrations">
                <div class="icon-wrap"><i class="bi bi-people-fill"></i></div>
                <div class="stat-value"><%= regCount %></div>
                <div class="stat-label">报名数量</div>
            </a>
            <a class="stat-card users" href="/admin/registrations?status=pending">
                <div class="icon-wrap"><i class="bi bi-hourglass-split"></i></div>
                <div class="stat-value"><%= regPending %></div>
                <div class="stat-label">待审核报名</div>
            </a>
            <a class="stat-card works" href="/admin/works">
                <div class="icon-wrap"><i class="bi bi-folder2-open"></i></div>
                <div class="stat-value"><%= workCount %></div>
                <div class="stat-label">作品数量</div>
            </a>
            <a class="stat-card anns" href="/admin/announcements">
                <div class="icon-wrap"><i class="bi bi-megaphone-fill"></i></div>
                <div class="stat-value"><%= annCount %></div>
                <div class="stat-label">公告数量</div>
            </a>
        </div>

        <div class="section-card">
            <div class="section-header">
                <h4><i class="bi bi-pie-chart-fill"></i> 作品统计</h4>
                <a href="/admin/works" class="btn-outline-admin btn-sm">查看全部 <i class="bi bi-arrow-right"></i></a>
            </div>
            <div class="work-stat-row">
                <a class="work-stat-chip total" href="/admin/works">
                    <div class="ws-value"><%= workCount %></div>
                    <div class="ws-label">全部作品</div>
                </a>
                <a class="work-stat-chip pending" href="/admin/works?status=submitted">
                    <div class="ws-value"><%= workPending %></div>
                    <div class="ws-label">待审核</div>
                </a>
                <a class="work-stat-chip approved" href="/admin/works?status=approved">
                    <div class="ws-value"><%= workApproved %></div>
                    <div class="ws-label">已通过</div>
                </a>
                <a class="work-stat-chip rejected" href="/admin/works?status=rejected">
                    <div class="ws-value"><%= workRejected %></div>
                    <div class="ws-label">已拒绝</div>
                </a>
            </div>
        </div>

        <div class="section-card">
            <div class="section-header">
                <h4><i class="bi bi-clock-history"></i> 最新报名</h4>
                <a href="/admin/registrations" class="btn-outline-admin btn-sm">查看全部 <i class="bi bi-arrow-right"></i></a>
            </div>
            <div class="admin-table">
                <table class="table">
                    <thead><tr><th>姓名</th><th>手机号</th><th>项目名称</th><th>赛道</th><th>状态</th><th>报名时间</th></tr></thead>
                    <tbody>
                        <% if (recentRegs.length > 0) { %>
                            <% recentRegs.forEach(r => { %>
                            <tr>
                                <td><strong><%= r.name %></strong></td>
                                <td><%= r.phone %></td>
                                <td><%= r.project_name %></td>
                                <td><span class="badge bg-secondary"><%= r.project_category || '-' %></span></td>
                                <td><span class="badge-status badge-<%= r.status %>"><%= r.status === 'pending' ? '待审核' : r.status === 'approved' ? '已通过' : '已拒绝' %></span></td>
                                <td><%= new Date(r.created_at).toLocaleString('zh-CN') %></td>
                            </tr>
                            <% }) %>
                        <% } else { %>
                            <tr><td colspan="6" class="empty-state"><i class="bi bi-inbox"></i><div>暂无报名数据</div></td></tr>
                        <% } %>
                    </tbody>
                </table>
            </div>
        </div>

        <div class="section-card">
            <div class="section-header">
                <h4><i class="bi bi-folder-check"></i> 最新作品</h4>
                <a href="/admin/works" class="btn-outline-admin btn-sm">查看全部 <i class="bi bi-arrow-right"></i></a>
            </div>
            <div class="admin-table">
                <table class="table">
                    <thead><tr><th>作品名称</th><th>提交者</th><th>赛道</th><th>状态</th><th>提交时间</th></tr></thead>
                    <tbody>
                        <% if (recentWorks.length > 0) { %>
                            <% recentWorks.forEach(w => { %>
                            <tr>
                                <td><strong><%= w.title %></strong></td>
                                <td><%= w.username || '-' %></td>
                                <td><span class="badge bg-secondary"><%= w.category || '-' %></span></td>
                                <td><span class="badge-status badge-<%= w.status %>"><%= w.status === 'submitted' ? '待审核' : w.status === 'approved' ? '已通过' : '已拒绝' %></span></td>
                                <td><%= new Date(w.submitted_at).toLocaleString('zh-CN') %></td>
                            </tr>
                            <% }) %>
                        <% } else { %>
                            <tr><td colspan="5" class="empty-state"><i class="bi bi-inbox"></i><div>暂无作品数据</div></td></tr>
                        <% } %>
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
