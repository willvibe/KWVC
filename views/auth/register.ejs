<!DOCTYPE html>
<html lang="zh-CN">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %></title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css" rel="stylesheet">
    <link rel="stylesheet" href="/css/style.css">
    <style>
        .register-bg { background: linear-gradient(135deg, #1a3a6c 0%, #2d5a87 100%); min-height: calc(100vh - 76px); padding: 100px 0 40px; }
        .register-header { text-align: center; color: #fff; margin-bottom: 32px; }
        .register-header h2 { font-size: 1.8rem; font-weight: 700; margin-bottom: 8px; }
        .register-header p { font-size: 1rem; opacity: 0.85; margin: 0; }
        .register-card { background: #fff; border-radius: 16px; box-shadow: 0 8px 32px rgba(0,0,0,0.12); padding: 32px; }
        .register-card h3 { color: #1a3a6c; font-weight: 700; margin-bottom: 24px; font-size: 1.4rem; }
        .form-section { margin-bottom: 24px; }
        .form-section-title { color: #1a3a6c; font-weight: 600; font-size: 1rem; margin-bottom: 16px; display: flex; align-items: center; gap: 8px; }
        .form-section-title i { color: #c8a45c; }
        .btn-hero-primary { background: linear-gradient(135deg, #1a3a6c, #2d5a87); color: #fff; border: none; padding: 12px 28px; border-radius: 8px; font-weight: 600; text-decoration: none; display: inline-block; transition: all 0.3s; }
        .btn-hero-primary:hover { background: linear-gradient(135deg, #2d5a87, #3d6a97); color: #fff; transform: translateY(-2px); box-shadow: 0 6px 20px rgba(26,58,108,0.3); }
        .form-actions { margin-top: 24px; }
    </style>
</head>
<body>
    <nav class="navbar navbar-expand-lg navbar-dark fixed-top" id="mainNav" style="background: #1a3a6c;">
        <div class="container">
            <a class="navbar-brand d-flex align-items-center" href="/">
                <img src="/images/kaiwen-logo.png" alt="凯文教育" class="nav-logo-img" onerror="this.onerror=null;this.src='/images/logo-white.svg'" style="height:40px;">
            </a>
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse" id="navbarNav">
                <ul class="navbar-nav ms-auto">
                    <li class="nav-item"><a class="nav-link" href="/">首页</a></li>
                    <li class="nav-item"><a class="nav-link" href="/about">大赛介绍</a></li>
                    <li class="nav-item"><a class="nav-link" href="/announcements">动态公告</a></li>
                    <% if (typeof user !== 'undefined' && user) { %>
                    <li class="nav-item"><a class="nav-link" href="/my"><i class="bi bi-person-fill"></i> 个人中心</a></li>
                    <li class="nav-item"><a class="nav-link" href="/logout"><i class="bi bi-box-arrow-right"></i> 退出</a></li>
                    <% } else { %>
                    <li class="nav-item"><a class="nav-link" href="/auth/login"><i class="bi bi-box-arrow-in-right"></i> 登录</a></li>
                    <li class="nav-item"><a class="nav-link active" href="/auth/register"><i class="bi bi-person-plus"></i> 注册</a></li>
                    <% } %>
                </ul>
            </div>
        </div>
    </nav>

    <main>
        <section class="register-bg">
            <div class="container">
                <div class="row justify-content-center">
                    <div class="col-lg-8">
                        <div class="register-header">
                            <h2>注册并报名</h2>
                            <p>创建账号并填写报名信息，一步完成大赛报名</p>
                        </div>
                        <div class="register-card">
                            <% if (error) { %>
                            <div class="alert alert-danger"><i class="bi bi-exclamation-triangle-fill"></i> <%= error %></div>
                            <% } %>
                            <form action="/auth/register" method="POST" id="registerForm" novalidate>
                                <div class="form-section">
                                    <h3 class="form-section-title"><i class="bi bi-person-plus-fill"></i> 创建账号</h3>
                                    <div class="row g-3">
                                        <div class="col-md-6">
                                            <label class="form-label">用户名 <span class="text-danger">*</span></label>
                                            <input type="text" class="form-control" name="username" value="<%= formData ? formData.username || '' : '' %>" required placeholder="至少3个字符">
                                        </div>
                                        <div class="col-md-6">
                                            <label class="form-label">真实姓名 <span class="text-danger">*</span></label>
                                            <input type="text" class="form-control" name="real_name" value="<%= formData ? formData.real_name || '' : '' %>" required placeholder="请输入真实姓名">
                                        </div>
                                        <div class="col-md-6">
                                            <label class="form-label">密码 <span class="text-danger">*</span></label>
                                            <input type="password" class="form-control" name="password" required placeholder="至少6个字符">
                                        </div>
                                        <div class="col-md-6">
                                            <label class="form-label">确认密码 <span class="text-danger">*</span></label>
                                            <input type="password" class="form-control" name="confirm_password" required placeholder="再次输入密码">
                                        </div>
                                        <div class="col-md-6">
                                            <label class="form-label">手机号码 <span class="text-danger">*</span></label>
                                            <input type="tel" class="form-control" name="phone" value="<%= formData ? formData.phone || '' : '' %>" required placeholder="请输入11位手机号" pattern="^1[3-9]\d{9}$">
                                        </div>
                                        <div class="col-md-6">
                                            <label class="form-label">电子邮箱 <span class="text-danger">*</span></label>
                                            <input type="email" class="form-control" name="email" value="<%= formData ? formData.email || '' : '' %>" required placeholder="请输入邮箱地址">
                                        </div>
                                        <div class="col-md-6">
                                            <label class="form-label">学校名称 <span class="text-danger">*</span></label>
                                            <input type="text" class="form-control" name="school" value="<%= formData ? formData.school || '' : '' %>" required placeholder="请输入学校名称">
                                        </div>
                                        <div class="col-md-6">
                                            <label class="form-label">所在学院 <span class="text-danger">*</span></label>
                                            <input type="text" class="form-control" name="college" value="<%= formData ? formData.college || '' : '' %>" required placeholder="请输入学院名称">
                                        </div>
                                        <div class="col-md-6">
                                            <label class="form-label">身份证号</label>
                                            <input type="text" class="form-control" name="id_card" value="<%= formData ? formData.id_card || '' : '' %>" placeholder="选填">
                                        </div>
                                        <div class="col-md-6">
                                            <label class="form-label">所在单位</label>
                                            <input type="text" class="form-control" name="company_school" value="<%= formData ? formData.company_school || '' : '' %>" placeholder="选填">
                                        </div>
                                        <div class="col-md-6">
                                            <label class="form-label">职业/职务</label>
                                            <input type="text" class="form-control" name="occupation" value="<%= formData ? formData.occupation || '' : '' %>" placeholder="选填">
                                        </div>
                                        <div class="col-md-6">
                                            <label class="form-label">性别</label>
                                            <select class="form-select" name="gender">
                                                <option value="male" <% if (!formData || !formData.gender || formData.gender === 'male') { %>selected<% } %>>男</option>
                                                <option value="female" <% if (formData && formData.gender === 'female') { %>selected<% } %>>女</option>
                                                <option value="other" <% if (formData && formData.gender === 'other') { %>selected<% } %>>其他</option>
                                            </select>
                                        </div>
                                    </div>
                                </div>

                                <div class="form-section">
                                    <h3 class="form-section-title"><i class="bi bi-lightbulb-fill"></i> 项目信息</h3>
                                    <div class="row g-3">
                                        <div class="col-md-6">
                                            <label class="form-label">项目名称 <span class="text-danger">*</span></label>
                                            <input type="text" class="form-control" name="project_name" value="<%= formData ? formData.project_name || '' : '' %>" required placeholder="请输入项目名称">
                                        </div>
                                        <div class="col-md-6">
                                            <label class="form-label">参赛赛道</label>
                                            <select class="form-select" name="project_category">
                                                <option value="">请选择赛道</option>
                                                <% (categories || []).forEach(c => { %>
                                                <option value="<%= c %>" <% if (formData && formData.project_category === c) { %>selected<% } %>><%= c %></option>
                                                <% }); %>
                                            </select>
                                        </div>
                                        <div class="col-12">
                                            <label class="form-label">项目简介</label>
                                            <textarea class="form-control" name="project_desc" rows="4" placeholder="请简要描述您的项目创意和功能特点"><%= formData ? formData.project_desc || '' : '' %></textarea>
                                        </div>
                                        <div class="col-12">
                                            <label class="form-label">团队成员</label>
                                            <textarea class="form-control" name="team_members" rows="2" placeholder="请填写团队成员姓名（如有），多人用逗号分隔"><%= formData ? formData.team_members || '' : '' %></textarea>
                                        </div>
                                        <div class="col-12">
                                            <label class="form-label">相关经验</label>
                                            <textarea class="form-control" name="experience" rows="2" placeholder="请简述您的零代码开发经验或相关项目经验"><%= formData ? formData.experience || '' : '' %></textarea>
                                        </div>
                                    </div>
                                </div>

                                <div class="form-section">
                                    <div class="form-check">
                                        <input class="form-check-input" type="checkbox" name="agree_rules" id="agreeRules" value="1" <% if (formData && formData.agree_rules) { %>checked<% } %> required>
                                        <label class="form-check-label" for="agreeRules">
                                            我已阅读并同意<a href="/about" target="_blank">《凯文杯大赛参赛规则》</a> <span class="text-danger">*</span>
                                        </label>
                                    </div>
                                </div>

                                <div class="form-actions">
                                    <button type="submit" class="btn btn-hero-primary btn-lg">
                                        <i class="bi bi-send-fill"></i> 注册并报名
                                    </button>
                                </div>
                            </form>
                            <div class="text-center mt-4">
                                <p style="color: var(--text-muted);">已有账号？<a href="/auth/login" style="color: var(--primary); font-weight: 600;">立即登录</a></p>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </section>
    </main>

    <footer class="site-footer">
        <div class="container">
            <div class="footer-bottom">
                <p>&copy; 2026 凯文教育集团 版权所有 | 凯文杯-首届VibeCoding零代码项目创作大赛</p>
            </div>
        </div>
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script src="/js/main.js"></script>
</body>
</html>