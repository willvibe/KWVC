<%- include('layout', { title, body: `

<section class="page-hero register-hero" style="padding: 15px 0; min-height: auto;">
    <div class="hero-overlay"></div>
    <div class="container hero-content">
        <h1>大赛报名</h1>
        <p>填写信息，加入凯文杯VibeCoding零代码项目创作大赛</p>
    </div>
</section>

${success ? `
<section class="section">
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-lg-6">
                <div class="success-card">
                    <div class="success-icon">
                        <i class="bi bi-check-circle-fill"></i>
                    </div>
                    <h2>报名成功！</h2>
                    <p>恭喜您已成功报名"凯文杯-首届VibeCoding零代码项目创作大赛"！</p>
                    <p>我们将在3个工作日内通过邮件或短信与您联系，请保持通讯畅通。</p>
                    <div class="success-actions">
                        <a href="/" class="btn btn-hero-primary">返回首页</a>
                        <a href="/announcements" class="btn btn-outline-primary">查看公告</a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>
` : `
<section class="section">
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-lg-8">
                ${error ? '<div class="alert alert-danger"><i class="bi bi-exclamation-triangle-fill"></i> ' + error + '</div>' : ''}
                <div class="register-form-card">
                    <form action="/register" method="POST" id="registerForm" novalidate>
                        <div class="form-section">
                            <h3 class="form-section-title"><i class="bi bi-person-fill"></i> 个人信息</h3>
                            <div class="row g-3">
                                <div class="col-md-6">
                                    <label class="form-label">姓名 <span class="text-danger">*</span></label>
                                    <input type="text" class="form-control" name="name" value="${formData.name || ''}" required placeholder="请输入您的姓名">
                                </div>
                                <div class="col-md-6">
                                    <label class="form-label">性别</label>
                                    <select class="form-select" name="gender">
                                        <option value="male" ${(!formData.gender || formData.gender === 'male') ? 'selected' : ''}>男</option>
                                        <option value="female" ${formData.gender === 'female' ? 'selected' : ''}>女</option>
                                        <option value="other" ${formData.gender === 'other' ? 'selected' : ''}>其他</option>
                                    </select>
                                </div>
                                <div class="col-md-6">
                                    <label class="form-label">手机号码 <span class="text-danger">*</span></label>
                                    <input type="tel" class="form-control" name="phone" value="${formData.phone || ''}" required placeholder="请输入11位手机号" pattern="^1[3-9]\\d{9}$">
                                </div>
                                <div class="col-md-6">
                                    <label class="form-label">电子邮箱 <span class="text-danger">*</span></label>
                                    <input type="email" class="form-control" name="email" value="${formData.email || ''}" required placeholder="请输入邮箱地址">
                                </div>
                                <div class="col-md-6">
                                    <label class="form-label">身份证号</label>
                                    <input type="text" class="form-control" name="id_card" value="${formData.id_card || ''}" placeholder="选填">
                                </div>
                                <div class="col-md-6">
                                    <label class="form-label">学校名称 <span class="text-danger">*</span></label>
                                    <input type="text" class="form-control" name="school" value="${formData.school || ''}" required placeholder="请输入学校名称">
                                </div>
                                <div class="col-md-6">
                                    <label class="form-label">所在学院 <span class="text-danger">*</span></label>
                                    <input type="text" class="form-control" name="college" value="${formData.college || ''}" required placeholder="请输入学院名称">
                                </div>
                                <div class="col-md-6">
                                    <label class="form-label">所在单位</label>
                                    <input type="text" class="form-control" name="company_school" value="${formData.company_school || ''}" placeholder="选填">
                                </div>
                                <div class="col-md-6">
                                    <label class="form-label">职业/职务</label>
                                    <input type="text" class="form-control" name="occupation" value="${formData.occupation || ''}" placeholder="选填">
                                </div>
                            </div>
                        </div>

                        <div class="form-section">
                            <h3 class="form-section-title"><i class="bi bi-lightbulb-fill"></i> 项目信息</h3>
                            <div class="row g-3">
                                <div class="col-md-6">
                                    <label class="form-label">项目名称 <span class="text-danger">*</span></label>
                                    <input type="text" class="form-control" name="project_name" value="${formData.project_name || ''}" required placeholder="请输入项目名称">
                                </div>
                                <div class="col-md-6">
                                    <label class="form-label">参赛赛道</label>
                                    <select class="form-select" name="project_category">
                                        <option value="">请选择赛道</option>
                                        ${(categories || []).map(c => '<option value="' + c + '" ' + ((formData && formData.project_category === c) ? 'selected' : '') + '>' + c + '</option>').join('')}
                                    </select>
                                </div>
                                <div class="col-12">
                                    <label class="form-label">项目简介</label>
                                    <textarea class="form-control" name="project_desc" rows="4" placeholder="请简要描述您的项目创意和功能特点">${formData.project_desc || ''}</textarea>
                                </div>
                                <div class="col-12">
                                    <label class="form-label">团队成员</label>
                                    <textarea class="form-control" name="team_members" rows="2" placeholder="请填写团队成员姓名（如有），多人用逗号分隔">${formData.team_members || ''}</textarea>
                                </div>
                                <div class="col-12">
                                    <label class="form-label">相关经验</label>
                                    <textarea class="form-control" name="experience" rows="2" placeholder="请简述您的零代码开发经验或相关项目经验">${formData.experience || ''}</textarea>
                                </div>
                            </div>
                        </div>

                        <div class="form-section">
                            <div class="form-check">
                                <input class="form-check-input" type="checkbox" name="agree_rules" id="agreeRules" value="1" ${formData && formData.agree_rules ? 'checked' : ''} required>
                                <label class="form-check-label" for="agreeRules">
                                    我已阅读并同意<a href="/about" target="_blank">《凯文杯大赛参赛规则》</a> <span class="text-danger">*</span>
                                </label>
                            </div>
                        </div>

                        <div class="form-actions">
                            <button type="submit" class="btn btn-hero-primary btn-lg">
                                <i class="bi bi-send-fill"></i> 提交报名
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</section>
` }

` }) %>
