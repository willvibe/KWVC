<%- include('layout', { title, body: `

<section class="page-hero detail-hero" style="padding: 15px 0; min-height: auto;">
    <div class="hero-overlay"></div>
    <div class="container hero-content">
        <span class="announcement-type-tag type-${announcement.type} large">
            ${announcement.type === 'notice' ? '通知' : announcement.type === 'news' ? '新闻' : '更新'}
        </span>
        <h1>${announcement.title}</h1>
        <p><i class="bi bi-clock"></i> ${new Date(announcement.created_at).toLocaleString('zh-CN')}</p>
    </div>
</section>

<section class="section">
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-lg-8">
                <div class="detail-content">
                    ${announcement.content.split('\n').map(line => `<p>${line}</p>`).join('')}
                </div>
                <div class="detail-nav mt-5">
                    <a href="/announcements" class="btn btn-outline-primary">
                        <i class="bi bi-arrow-left"></i> 返回公告列表
                    </a>
                </div>
            </div>
        </div>
    </div>
</section>

` }) %>